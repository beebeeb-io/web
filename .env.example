# Vite — API base URL (default http://localhost:3001)
VITE_API_URL=http://localhost:3001

# Playwright e2e — test-account credentials.
# Used by e2e/helpers/auth.ts to drive the real OPAQUE login flow including
# the DeviceProvision recovery-phrase step. Copy to a local `.env` (gitignored)
# and fill in values from /beebeeb:test-accounts. NEVER commit real values.
BB_TEST_USER_EMAIL=
BB_TEST_USER_PASSWORD=
BB_TEST_USER_RECOVERY_PHRASE=
