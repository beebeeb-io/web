# Playwright test credentials — required for full E2E suite
# Create a dedicated test account via the signup flow, then fill in below.
# Keep SEPARATE from your personal account — tests create/delete files.
#
# How to create:
#   1. Open http://localhost:5173/signup (with local stack running)
#   2. Sign up with a test email (e.g. e2e-test@beebeeb.io)
#   3. Complete onboarding — SAVE the 12-word recovery phrase
#   4. Fill in below:
#
# Then run: cp .env.test.example .env.test
# Playwright picks up .env.test automatically via dotenv.

BB_TEST_USER_EMAIL=e2e-test@beebeeb.io
BB_TEST_USER_PASSWORD=your-test-password-here
BB_TEST_USER_RECOVERY_PHRASE=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
