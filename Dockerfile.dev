FROM oven/bun:1
WORKDIR /app

# Copy shared package (web depends on @beebeeb/shared via workspace)
COPY packages/shared /shared

# Copy WASM package (web depends on it via local path)
COPY repos/core/beebeeb-wasm/pkg /wasm-pkg

# Copy web app source (excluding node_modules via .dockerignore)
COPY repos/web/ .

# Remove .git so Tailwind v4 falls back to filesystem scanning (no git binary in container)
RUN rm -rf .git

# Rewrite local dependency paths for container and install
RUN sed -i 's|../../repos/core/beebeeb-wasm/pkg|/wasm-pkg|' package.json && \
    sed -i 's|"@beebeeb/shared": "workspace:\*"|"@beebeeb/shared": "/shared"|' package.json && \
    rm -rf node_modules && \
    bun install

EXPOSE 5173
CMD ["bun", "dev", "--host", "0.0.0.0"]
